{
  "name": "@opzero/cli",
  "version": "0.1.4",
  "private": false,
  "type": "module",
  "bin": {
    "codez": "./bin/codez"
  },
  "scripts": {
    "dev": "concurrently -n server,web -c cyan,magenta \"bun run dev:server\" \"bun run dev:web\"",
    "dev:server": "bun run --watch server/index.ts",
    "dev:web": "cd web && bun run dev",
    "build": "cd web && bun run build",
    "start": "bun run server/index.ts",
    "setup": "bun run bin/cli.ts setup",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "prepublishOnly": "cd web && bun run build"
  },
  "files": [
    "bin",
    "server",
    "web/dist",
    "packages/codezero-mcp",
    "scripts",
    "tsconfig.json",
    "README.md"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "concurrently": "^9.1.0",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opzero/codez-hub-client": "^0.1.0"
  }
}

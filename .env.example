# CodeZ environment variables
# Copy to .env and fill in your values

# Server
CODEZERO_PORT=4097
CODEZERO_HOST=127.0.0.1

# MCPAuthKit (required for remote MCP access)
# Deploy your own instance: https://github.com/OpZero-sh/MCPAuthKit
AUTHKIT_URL=https://authkit.yourdomain.com

# MCP server (standalone mode only)
CODEZERO_MCP_PORT=4098
CODEZERO_MCP_HOST=0.0.0.0
CODEZERO_MCP_URL=https://codez.yourdomain.com

# CodeZero API URL (standalone MCP server only)
CODEZERO_URL=http://127.0.0.1:4097

# CodeZ Hub (optional: overrides persisted config.hubUrl)
CODEZ_HUB_URL=https://code.open0p.com
